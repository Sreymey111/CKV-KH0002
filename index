                                await signInWithCustomToken(auth, __initial_auth_token);
                                console.log("Signed in with custom token.");
                            } catch (error) {
                                console.error("Error signing in with custom token:", error);
                                // Fallback to anonymous if custom token fails
                                await signInAnonymously(auth);
                                console.log("Signed in anonymously due to custom token failure.");
                            }
                        } else {
                            // If no custom token, sign in anonymously
                            await signInAnonymously(auth);
                            console.log("Signed in anonymously.");
                        }
                        // Even if anonymous, userId will be set by the next onAuthStateChanged trigger
                        // Or implicitly by getAuth().currentUser.uid if it's already signed in.
                    }
                    hideLoading(); // Hide loading after auth state is determined
                    console.log("hideLoading() called after onAuthStateChanged.");
                });

                initializeNoteMonthInput(); // Set the initial month for the notes input
            } catch (error) {
                console.error("Firebase initialization failed:", error);
                showMessage("ការចាប់ផ្តើមកម្មវិធីមានបញ្ហា។ សូមព្យាយាមម្តងទៀត។ (Application initialization failed. Please try again.)");
                hideLoading();
            }
        };
    </script>
