      "1. Complete: I ______ from Cambodia. (am/is/are)",
      "2. Complete: ______ do you live? — I live in Siem Reap.",
      "3. Translate to English: តើលេខទូរស័ព្ទរបស់អ្នកគឺអ្វី?",
      "4. Answer these 7 questions about yourself: name, age, country, city, job, phone number, hobbies."
    ]
  }
];
for(let i=3;i<=30;i++){
  const titles = ["Numbers & Age","Countries & Nationalities","My Family","Jobs & Occupations","Daily Routine","Telling the Time","Days, Months & Dates","Likes & Dislikes","Food & Drinks","At a Restaurant","My Home","There is / There are","Places in Town","Asking for Directions","Shopping & Prices","Clothes & Colors","Weather & Seasons","Hobbies & Free Time","Can / Can't","Present Simple","Present Continuous","Past Simple: was/were","Common Past Verbs","Future Plans: going to","Feelings & Emotions","Health & Body","Real-Life Conversation Practice","A1 Final Review & Test"];
  LESSONS.push({id:i, en:titles[i-3], km:"", comingSoon:true});
}

let progress = {completed:{}, scores:{}};
let profile = null; // {name, skin, hair, hairStyle, outfit, accessory}
let view = {screen:"home", lessonId:null, fcIndex:0, fcFlipped:false, quiz:null};

const AVATAR_OPTS = {
  skin: ["#FBE3C6","#F2C9A0","#D9A066","#A6693E","#6B4226"],
  hair: ["#2B1B12","#6B3E22","#C7963C","#D9587A","#4A4A4A","#3C6FA6"],
  hairStyle: [["short","ខ្លី"],["long","វែង"],["ponytail","ក្រវាត់សក់"]],
  outfit: ["#146C5C","#D2542E","#C9971B","#6B4FA0","#2F7FBF"],
  accessory: [["none","គ្មាន"],["glasses","វែនតា"],["bow","ខ្សែក"]]
};
function defaultProfile(){
  return {name:"", skin:AVATAR_OPTS.skin[1], hair:AVATAR_OPTS.hair[0], hairStyle:"short", outfit:AVATAR_OPTS.outfit[0], accessory:"none"};
}

function avatarSVG(p, size){
  size = size || 120;
  let hairBack = "";
  if(p.hairStyle==="long") hairBack = `<rect x="22" y="52" width="76" height="58" rx="26" fill="${p.hair}"/>`;
  if(p.hairStyle==="ponytail") hairBack = `<circle cx="94" cy="66" r="9" fill="${p.hair}"/><rect x="88" y="58" width="13" height="30" rx="6" fill="${p.hair}"/>`;
  let accessory = "";
  if(p.accessory==="glasses"){
    accessory = `<g stroke="#2B281F" stroke-width="3" fill="none"><circle cx="48" cy="52" r="10"/><circle cx="76" cy="52" r="10"/><line x1="58" y1="52" x2="66" y2="52"/></g>`;
  } else if(p.accessory==="bow"){
    accessory = `<g fill="${p.outfit==='#D2542E' ? '#146C5C' : '#D2542E'}"><path d="M60 8 L74 2 L74 16 Z"/><path d="M60 8 L46 2 L46 16 Z"/><circle cx="60" cy="8" r="4"/></g>`;
  }
  return `<svg viewBox="0 0 120 150" xmlns="http://www.w3.org/2000/svg">
    ${hairBack}
    <rect x="24" y="100" width="72" height="48" rx="22" fill="${p.outfit}"/>
    <circle cx="60" cy="52" r="34" fill="${p.skin}"/>
    <path d="M26 52 Q60 8 94 52 Q92 24 60 18 Q28 24 26 52 Z" fill="${p.hair}"/>
    <circle cx="49" cy="54" r="3.5" fill="#2B281F"/>
    <circle cx="71" cy="54" r="3.5" fill="#2B281F"/>
    <path d="M50 66 Q60 74 70 66" stroke="#2B281F" stroke-width="2.5" fill="none" stroke-linecap="round"/>
    ${accessory}
  </svg>`;
}

async function loadProgress(){
  try{
    const r = await window.storage.get("a1-progress");
    if(r && r.value) progress = JSON.parse(r.value);
  }catch(e){}
  try{
    const r2 = await window.storage.get("a1-profile");
    if(r2 && r2.value) profile = JSON.parse(r2.value);
  }catch(e){}
  if(!profile || !profile.name){
    view = {screen:"profile", draft:defaultProfile(), isNew:true};
  }
  render();
}
async function saveProgress(){
  try{ await window.storage.set("a1-progress", JSON.stringify(progress)); }catch(e){}
}
async function saveProfile(){
  profile = Object.assign({}, view.draft);
  try{ await window.storage.set("a1-profile", JSON.stringify(profile)); }catch(e){}
  goHome();
}
function openProfileEdit(){
  view = {screen:"profile", draft:Object.assign({}, profile), isNew:false};
  render();
}
function setDraft(key, val){ view.draft[key] = val; render(); }

function completedCount(){ return Object.keys(progress.completed).length; }

function goHome(){ view = {screen:"home", lessonId:null, fcIndex:0, fcFlipped:false, quiz:null}; render(); }
function openLesson(id){
  const lesson = LESSONS.find(l=>l.id===id);
  if(lesson.comingSoon) return;
  view = {screen:"lesson", lessonId:id, fcIndex:0, fcFlipped:false, quiz:null};
  render();
}

function isUnlocked(id){
  if(id===1) return true;
  return !!progress.completed[id-1];
}

function renderHome(){
  const total = LESSONS.length;
  const done = completedCount();
  let html = `<main>`;
  html += `<div class="section-title km">មេរៀនទាំងអស់</div><div class="lesson-list">`;
  LESSONS.forEach(l=>{
    const unlocked = isUnlocked(l.id);
    const isDone = !!progress.completed[l.id];
    const cls = ["lesson-card"];
    if(!unlocked) cls.push("locked");
    if(isDone) cls.push("done");
    if(unlocked && !isDone && l.id === done+1) cls.push("current");
    html += `<div class="${cls.join(' ')}" onclick="${unlocked && !l.comingSoon ? `openLesson(${l.id})` : ''}">`;
    html += `<div class="l-num">${isDone ? '✓' : l.id}</div>`;
    html += `<div class="l-body"><div class="l-title-en">${l.en}</div>`;
    html += `<div class="l-title-km km">${l.km || (l.comingSoon ? 'មេរៀននេះនឹងបន្ថែមឆាប់ៗនេះ' : '')}</div></div>`;
    if(!unlocked) html += `<span class="l-lock-icon">🔒</span>`;
    else if(isDone) html += `<span class="l-status km">បញ្ចប់</span>`;
    html += `</div>`;
  });
  html += `</div></main>`;
  return html;
}

function renderLesson(){
  const l = LESSONS.find(x=>x.id===view.lessonId);
  let html = `<main>`;
  html += `<div class="back-row" onclick="goHome()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg> ត្រឡប់ក្រោយ</div>`;
  html += `<div class="l-header"><div class="l-eyebrow">មេរៀនទី ${l.id}</div>`;
  html += `<div class="l-name-en">${l.en}</div><div class="l-name-km km">${l.km}</div>`;
  html += `<div class="goal-box km">🎯 ${l.goal}</div></div>`;

  // vocab flashcards
  const v = l.vocab[view.fcIndex];
  html += `<div class="card"><h3>📇 វាក្យសព្ទ (${view.fcIndex+1}/${l.vocab.length})</h3>`;
  html += `<div class="flip-card" onclick="flipCard()">`;
  if(!view.fcFlipped){
    html += `<div class="flip-front">${v[0]}</div><div class="flip-hint km">ចុចដើម្បីមើលការអាន</div>`;
  } else {
    html += `<div class="flip-back" style="display:flex;flex-direction:column;">
      <div class="en">${v[0]}</div><div class="kh-read km">${v[1]}</div><div class="kh-mean km">${v[2]}</div>
    </div>`;
  }
  html += `</div>`;
  html += `<div class="fc-nav"><button onclick="fcNav(-1)">◀ មុន</button><button onclick="fcNav(1)">បន្ទាប់ ▶</button></div>`;
  html += `</div>`;

  // key sentences
  html += `<div class="card"><h3 class="km">💬 ប្រយោគសំខាន់ៗ</h3>`;
  l.sentences.forEach(s=>{
    html += `<div class="sentence"><div class="en">${s[0]}</div><div class="kh km">${s[1]}</div></div>`;
  });
  html += `</div>`;

  // grammar
  html += `<div class="card"><h3>📐 Grammar — ${l.grammar.title}</h3><table class="gram"><tr><th>Subject</th><th>Verb</th><th>Example</th></tr>`;
  l.grammar.rows.forEach(r=>{ html += `<tr><td>${r[0]}</td><td>${r[1]}</td><td>${r[2]}</td></tr>`; });
  html += `</table></div>`;

  // dialogue
  if(l.dialogue){
    html += `<div class="card"><h3 class="km">🎤 ហាត់សន្ទនា</h3>`;
    l.dialogue.forEach(d=>{
      html += `<div class="sentence"><div class="en"><b>${d[0]}:</b> ${d[1]}</div><div class="kh km">${d[2]}</div></div>`;
    });
    html += `<div class="km" style="font-size:12px;color:var(--ink-soft);margin-top:4px;">អានឲ្យបានច្បាស់ ៣ ដង៖ លើកទី១ យឺតៗ, លើកទី២ មិនបកប្រែ, លើកទី៣ ដោយមិនមើលអត្ថបទ។</div>`;
    html += `</div>`;
  }

  // exercises
  if(l.exercises){
    html += `<div class="card"><h3 class="km">✍️ លំហាត់</h3>`;
    l.exercises.forEach(ex=>{
      html += `<div class="sentence km" style="font-size:13.5px;">${ex}</div>`;
    });
    html += `<div class="km" style="font-size:12px;color:var(--ink-soft);margin-top:4px;">សរសេរចម្លើយក្នុង Chat ដើម្បីឲ្យខ្ញុំកែឲ្យអ្នក។</div>`;
    html += `</div>`;
  }

  html += `<button class="primary full" onclick="startQuiz()">ធ្វើតេស្តខ្លីៗ (Quiz) →</button>`;
  html += `</main>`;
  return html;
}

function flipCard(){ view.fcFlipped = !view.fcFlipped; render(); }
function fcNav(dir){
  const l = LESSONS.find(x=>x.id===view.lessonId);
  view.fcIndex = (view.fcIndex + dir + l.vocab.length) % l.vocab.length;
  view.fcFlipped = false;
  render();
}

function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){ const j = Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; }
  return a;
}

function startQuiz(){
  const l = LESSONS.find(x=>x.id===view.lessonId);
  const items = shuffle(l.vocab.map(v=>({q:v[0],a:v[2]}))).slice(0, Math.min(10, l.vocab.length));
  view.quiz = {items, idx:0, score:0, answered:false};
  render();
}

function renderQuiz(){
  const l = LESSONS.find(x=>x.id===view.lessonId);
  const q = view.quiz;
  let html = `<main>`;
  html += `<div class="back-row" onclick="view.quiz=null;render();"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg> ត្រឡប់ក្រោយ</div>`;

  if(q.idx >= q.items.length){
    const pct = Math.round(100*q.score/q.items.length);
    html += `<div class="card quiz-result">`;
    html += `<div class="km" style="font-size:14px;color:var(--ink-soft);">លទ្ធផលរបស់អ្នក</div>`;
    html += `<div class="big">${q.score}/${q.items.length}</div>`;
    html += `<div class="km" style="margin:6px 0 18px;">${pct>=70 ? 'ល្អណាស់! 🎉' : 'ព្យាយាមម្តងទៀត!'}</div>`;
    html += `<button class="primary full" onclick="completeLesson(${l.id})">បញ្ចប់មេរៀន ✓</button>`;
    html += `</div>`;
    html += `</main>`;
    return html;
  }

  const item = q.items[q.idx];
  const allMeanings = LESSONS.filter(x=>!x.comingSoon).flatMap(x=>x.vocab.map(v=>v[2]));
  if(!q._opts || q._optsFor !== q.idx){
    const wrongs = shuffle(allMeanings.filter(m=>m!==item.a)).slice(0,3);
    q._opts = shuffle([item.a, ...wrongs]);
    q._optsFor = q.idx;
  }
  html += `<div class="card">`;
  html += `<div class="km" style="font-size:12px;color:var(--ink-soft);text-align:center;">សំណួរ ${q.idx+1} / ${q.items.length}</div>`;
  html += `<div class="quiz-q">${item.q}</div>`;
  html += `<div class="quiz-opts km">`;
  q._opts.forEach(opt=>{
    let cls = "";
    if(q.answered){
      if(opt===item.a) cls="correct";
      else if(opt===q.picked && opt!==item.a) cls="wrong";
    }
    html += `<button class="${cls}" onclick="answerQuiz('${opt.replace(/'/g,"\\'")}')" ${q.answered?'disabled':''}>${opt}</button>`;
  });
  html += `</div><div class="quiz-feedback km">${q.answered ? (q.picked===item.a ? 'ត្រឹមត្រូវ! ✓' : 'មិនត្រឹមត្រូវ') : ''}</div>`;
  if(q.answered){
    html += `<button class="primary full" style="margin-top:10px;" onclick="nextQuiz()">បន្ទាប់ →</button>`;
  }
  html += `</div></main>`;
  return html;
}

function answerQuiz(opt){
  const q = view.quiz;
  if(q.answered) return;
  q.answered = true;
  q.picked = opt;
  const item = q.items[q.idx];
  if(opt === item.a) q.score++;
  render();
}
function nextQuiz(){
  view.quiz.idx++;
  view.quiz.answered = false;
  view.quiz.picked = null;
  render();
}
async function completeLesson(id){
  progress.completed[id] = true;
  progress.scores[id] = view.quiz.score + "/" + view.quiz.items.length;
  await saveProgress();
  goHome();
}

function render(){
  const app = document.getElementById("app");
  const total = LESSONS.length;
  const done = completedCount();
  const pct = Math.round(100*done/total);

  let headerHtml;
  if(view.screen === "profile"){
    headerHtml = `<header class="top"><div class="brand km">${view.isNew ? 'បង្កើតប្រវត្តិរូប' : 'កែប្រវត្តិរូប'}</div></header>`;
  } else {
    const avatarMarkup = profile ? avatarSVG(profile, 44) : `<span style="font-size:20px;">🎓</span>`;
    headerHtml = `<header class="top">
      <div class="header-row">
        <div class="avatar-btn" onclick="openProfileEdit()">${avatarMarkup}</div>
        <div style="flex:1;">
          <div class="greeting km">${profile && profile.name ? 'សួស្តី, ' + profile.name + '!' : 'English A1'}</div>
          <div class="greeting-sub badge" style="display:inline-block;margin-top:2px;">${done}/${total}</div>
        </div>
      </div>
      <div class="progress-wrap">
        <div class="progress-label km"><span>វឌ្ឍនភាព</span><span>${pct}%</span></div>
        <div class="progress-track"><div class="progress-fill" style="width:${pct}%;"></div></div>
      </div>
    </header>`;
  }

  let bodyHtml = "";
  if(view.screen === "profile") bodyHtml = renderProfile();
  else if(view.screen === "home") bodyHtml = renderHome();
  else if(view.screen === "lesson"){
    bodyHtml = view.quiz ? renderQuiz() : renderLesson();
  }
  app.innerHTML = headerHtml + bodyHtml;
}

function renderProfile(){
  const d = view.draft;
  let html = `<main>`;
  if(!view.isNew){
    html += `<div class="back-row" onclick="goHome()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg> ត្រឡប់ក្រោយ</div>`;
  } else {
    html += `<div class="km" style="text-align:center;color:var(--ink-soft);font-size:13.5px;margin-bottom:14px;">មុននឹងចាប់ផ្តើមរៀន សូមបង្កើតតុក្កតារបស់អ្នក!</div>`;
  }

  html += `<div class="avatar-stage">${avatarSVG(d, 150)}</div>`;

  html += `<div class="field-label km">ឈ្មោះរបស់អ្នក</div>
    <input class="name-input km" id="name-field" type="text" placeholder="បញ្ចូលឈ្មោះ" value="${d.name.replace(/"/g,'&quot;')}" oninput="onNameInput(this.value)" style="margin-bottom:1.1rem;">`;

  html += `<div class="field-label km">ពណ៌សម្បុរ</div><div class="swatch-row">`;
  AVATAR_OPTS.skin.forEach(c=>{
    html += `<div class="swatch ${d.skin===c?'selected':''}" style="background:${c};" onclick="setDraft('skin','${c}')"></div>`;
  });
  html += `</div>`;

  html += `<div class="field-label km">ពណ៌សក់</div><div class="swatch-row">`;
  AVATAR_OPTS.hair.forEach(c=>{
    html += `<div class="swatch ${d.hair===c?'selected':''}" style="background:${c};" onclick="setDraft('hair','${c}')"></div>`;
  });
  html += `</div>`;

  html += `<div class="field-label km">ម៉ូតសក់</div><div class="opt-row km">`;
  AVATAR_OPTS.hairStyle.forEach(([val,label])=>{
    html += `<button class="opt-btn ${d.hairStyle===val?'selected':''}" onclick="setDraft('hairStyle','${val}')">${label}</button>`;
  });
  html += `</div>`;

  html += `<div class="field-label km">ពណ៌សម្លៀកបំពាក់</div><div class="swatch-row">`;
  AVATAR_OPTS.outfit.forEach(c=>{
    html += `<div class="swatch ${d.outfit===c?'selected':''}" style="background:${c};" onclick="setDraft('outfit','${c}')"></div>`;
  });
  html += `</div>`;

  html += `<div class="field-label km">គ្រឿងតុបតែង</div><div class="opt-row km">`;
  AVATAR_OPTS.accessory.forEach(([val,label])=>{
    html += `<button class="opt-btn ${d.accessory===val?'selected':''}" onclick="setDraft('accessory','${val}')">${label}</button>`;
  });
  html += `</div>`;

  html += `<button class="primary full km" id="save-profile-btn" onclick="saveProfile()" ${d.name.trim()?'':'disabled'}>${view.isNew ? 'ចាប់ផ្តើមរៀន' : 'រក្សាទុក'} →</button>`;
  html += `</main>`;
  return html;
}

function onNameInput(val){
  view.draft.name = val;
  const btn = document.getElementById("save-profile-btn");
  if(btn) btn.disabled = !val.trim();
}

loadProgress();
</script>
