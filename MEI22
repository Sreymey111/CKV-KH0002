<!DOCTYPE html>
<html lang="km">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
<title>English A1 — កម្មវិធីសិក្សា</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600&family=Inter:wght@400;500;600&family=Noto+Sans+Khmer:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #F5F4EC;
    --surface: #FFFFFF;
    --surface-2: #EEF2ED;
    --ink: #21281F;
    --ink-soft: #5C6355;
    --teal: #146C5C;
    --teal-dark: #0C4E42;
    --teal-tint: #E1EFEA;
    --gold: #C9971B;
    --gold-tint: #FBF0D6;
    --coral: #D2542E;
    --coral-tint: #FBE7DF;
    --border: #E2E0D3;
    --radius: 16px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--bg);
    color:var(--ink);
    font-family:'Inter','Noto Sans Khmer',sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  .km{font-family:'Noto Sans Khmer','Inter',sans-serif;}
  .app{max-width:480px;margin:0 auto;min-height:100vh;position:relative;padding-bottom:2rem;}

  header.top{
    position:sticky;top:0;z-index:10;
    background:var(--teal);color:#fff;
    padding:1.1rem 1.25rem 1.4rem;
    border-radius:0 0 24px 24px;
  }
  header.top .brand{
    font-family:'Fredoka',sans-serif;font-weight:600;font-size:22px;
    display:flex;align-items:center;gap:8px;
  }
  header.top .brand .badge{
    font-family:'Inter';font-weight:600;font-size:12px;
    background:rgba(255,255,255,0.18);padding:3px 9px;border-radius:20px;
  }
  .progress-wrap{margin-top:14px;}
  .progress-label{font-size:12.5px;opacity:0.85;margin-bottom:6px;display:flex;justify-content:space-between;}
  .progress-track{height:8px;background:rgba(255,255,255,0.22);border-radius:20px;overflow:hidden;}
  .progress-fill{height:100%;background:var(--gold);border-radius:20px;transition:width .4s ease;}

  main{padding:1.25rem 1.1rem;}

  /* ===== Home: lesson list ===== */
  .section-title{font-family:'Fredoka',sans-serif;font-weight:600;font-size:18px;margin:0 0 12px;}
  .lesson-list{display:flex;flex-direction:column;gap:10px;}
  .lesson-card{
    display:flex;align-items:center;gap:12px;
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
    padding:12px 14px;cursor:pointer;transition:transform .12s ease, border-color .12s ease;
  }
  .lesson-card:active{transform:scale(0.98);}
  .lesson-card.locked{opacity:0.55;cursor:default;}
  .lesson-card.done{border-color:var(--teal);}
  .l-num{
    width:38px;height:38px;border-radius:50%;flex:0 0 auto;
    display:flex;align-items:center;justify-content:center;
    font-family:'Fredoka',sans-serif;font-weight:600;font-size:15px;
    background:var(--surface-2);color:var(--ink-soft);
  }
  .lesson-card.done .l-num{background:var(--teal);color:#fff;}
  .lesson-card.current .l-num{background:var(--gold);color:#fff;}
  .l-body{flex:1;min-width:0;}
  .l-title-en{font-weight:600;font-size:14.5px;}
  .l-title-km{font-size:12.5px;color:var(--ink-soft);margin-top:1px;}
  .l-status{font-size:11px;color:var(--teal);flex:0 0 auto;}
  .l-lock-icon{color:var(--ink-soft);font-size:16px;flex:0 0 auto;}

  /* ===== Lesson detail ===== */
  .back-row{display:flex;align-items:center;gap:8px;margin-bottom:14px;cursor:pointer;color:var(--teal-dark);font-weight:500;font-size:14px;}
  .back-row svg{flex:0 0 auto;}
  .l-header{margin-bottom:1.1rem;}
  .l-eyebrow{font-size:12px;color:var(--teal);font-weight:600;letter-spacing:.03em;text-transform:uppercase;}
  .l-name-en{font-family:'Fredoka',sans-serif;font-weight:600;font-size:22px;margin:2px 0 4px;}
  .l-name-km{font-size:14px;color:var(--ink-soft);}
  .goal-box{
    background:var(--gold-tint);border-radius:12px;padding:10px 14px;margin-top:12px;
    font-size:13.5px;color:#5C4712;
  }

  .card{
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
    padding:1rem 1.1rem;margin-bottom:1rem;
  }
  .card h3{
    font-family:'Fredoka',sans-serif;font-weight:600;font-size:15px;margin:0 0 10px;
    display:flex;align-items:center;gap:6px;color:var(--teal-dark);
  }

  /* flashcards */
  .fc-progress{font-size:12px;color:var(--ink-soft);text-align:center;margin-bottom:8px;}
  .flip-card{
    background:var(--teal-tint);border-radius:14px;min-height:130px;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;padding:1rem;cursor:pointer;user-select:none;
  }
  .flip-front{font-family:'Fredoka',sans-serif;font-weight:600;font-size:26px;color:var(--teal-dark);}
  .flip-back{display:none;}
  .flip-back .en{font-family:'Fredoka',sans-serif;font-weight:600;font-size:22px;color:var(--teal-dark);}
  .flip-back .kh-read{font-size:14px;color:var(--teal);margin-top:4px;}
  .flip-back .kh-mean{font-size:16px;font-weight:500;margin-top:6px;}
  .flip-hint{font-size:11px;color:var(--ink-soft);margin-top:8px;}
  .fc-nav{display:flex;gap:8px;margin-top:10px;}
  .fc-nav button{flex:1;}

  button{
    font-family:'Inter',sans-serif;font-size:13.5px;font-weight:500;
    background:var(--surface);border:1px solid var(--border);border-radius:10px;
    padding:9px 12px;color:var(--ink);cursor:pointer;
  }
  button:active{transform:scale(0.97);}
  button.primary{background:var(--teal);border-color:var(--teal);color:#fff;}
  button.full{width:100%;padding:12px;font-size:14.5px;font-weight:600;border-radius:12px;}

  .sentence{margin-bottom:10px;}
  .sentence .en{font-weight:600;font-size:14.5px;}
  .sentence .kh{font-size:13px;color:var(--ink-soft);margin-top:2px;}

  table.gram{width:100%;border-collapse:collapse;font-size:13px;}
  table.gram th{background:var(--surface-2);text-align:left;padding:6px 8px;font-weight:600;}
  table.gram td{padding:6px 8px;border-top:1px solid var(--border);}

  /* quiz */
  .quiz-q{font-family:'Fredoka',sans-serif;font-weight:600;font-size:26px;text-align:center;padding:1.2rem 0 1rem;}
  .quiz-opts{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
  .quiz-opts button{padding:12px 8px;font-size:13px;}
  .quiz-opts button.correct{background:var(--teal);border-color:var(--teal);color:#fff;}
  .quiz-opts button.wrong{background:var(--coral-tint);border-color:var(--coral);color:var(--coral);}
  .quiz-feedback{text-align:center;font-size:13.5px;min-height:18px;margin-top:10px;font-weight:500;}
  .quiz-result{text-align:center;padding:1.5rem 0;}
  .quiz-result .big{font-family:'Fredoka',sans-serif;font-weight:600;font-size:34px;color:var(--teal);}

  .empty-note{
    text-align:center;color:var(--ink-soft);font-size:13px;
    padding:2rem 1rem;background:var(--surface);border-radius:var(--radius);border:1px dashed var(--border);
  }

  /* ===== Profile / avatar header button ===== */
  .header-row{display:flex;align-items:center;gap:10px;}
  .avatar-btn{
    width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,0.18);
    display:flex;align-items:center;justify-content:center;flex:0 0 auto;cursor:pointer;
    border:2px solid rgba(255,255,255,0.5);overflow:hidden;
  }
  .avatar-btn svg{width:100%;height:100%;}
  .greeting{font-family:'Fredoka',sans-serif;font-weight:600;font-size:16px;}
  .greeting-sub{font-size:11.5px;opacity:0.85;margin-top:1px;}

  /* ===== Profile builder screen ===== */
  .avatar-stage{
    display:flex;align-items:center;justify-content:center;
    background:var(--teal-tint);border-radius:20px;padding:1.2rem;margin-bottom:1.1rem;
  }
  .avatar-stage svg{width:150px;height:150px;}
  .field-label{font-family:'Fredoka',sans-serif;font-weight:600;font-size:14px;margin:0 0 8px;color:var(--teal-dark);}
  .name-input{
    width:100%;padding:11px 14px;border-radius:12px;border:1px solid var(--border);
    font-size:15px;font-family:'Inter','Noto Sans Khmer',sans-serif;background:var(--surface);
  }
  .swatch-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1.1rem;}
  .swatch{
    width:36px;height:36px;border-radius:50%;cursor:pointer;border:2px solid transparent;
    display:flex;align-items:center;justify-content:center;
  }
  .swatch.selected{border-color:var(--ink);}
  .opt-row{display:flex;gap:8px;margin-bottom:1.1rem;flex-wrap:wrap;}
  .opt-btn{padding:9px 14px;border-radius:20px;font-size:13px;}
  .opt-btn.selected{background:var(--teal);border-color:var(--teal);color:#fff;}
</style>
</head>
<body>
<div class="app" id="app"></div>

